    },
    {
      "pair_key": "anxious_vs_relaxed",
      "left": "anxious",
      "right": "relaxed",
      "directions": {
        "anxious_vs_relaxed": {
          "formula": "normalize(mean(anxious) - mean(relaxed))"
        },
        "relaxed_vs_anxious": {
          "formula": "-( anxious_vs_relaxed )",
