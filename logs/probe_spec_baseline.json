{
  "version": "step2-probe-design-v1",
  "required_record_fields": [
    "id",
    "text"
  ],
  "dataset_layouts_supported": [
    "ROOT/{pair_key}/{split}/{side}.jsonl",
    "ROOT/{pair_key}__{split}__{side}.jsonl"
  ],
  "splits": [
    "train",
    "val",
    "test"
  ],
  "pair_specs": [
    {
      "pair_key": "sad_vs_happy",
      "left": "sad",
      "right": "happy",
      "directions": {
        "sad_vs_happy": {
          "formula": "normalize(mean(sad) - mean(happy))"
        },
        "happy_vs_sad": {
          "formula": "-( sad_vs_happy )",
          "note": "Implicit opposite direction."
        }
      },
      "score_rule": "cosine(residual, direction)",
      "percentage_rule": {
        "p_sad": "sigmoid(k * score)",
        "p_happy": "1 - p_sad"
      }
    },
    {
      "pair_key": "angry_vs_calm",
      "left": "angry",
      "right": "calm",
      "directions": {
        "angry_vs_calm": {
          "formula": "normalize(mean(angry) - mean(calm))"
        },
        "calm_vs_angry": {
          "formula": "-( angry_vs_calm )",
          "note": "Implicit opposite direction."
        }
      },
      "score_rule": "cosine(residual, direction)",
      "percentage_rule": {
        "p_angry": "sigmoid(k * score)",
        "p_calm": "1 - p_angry"
      }
    },
    {
      "pair_key": "fear_vs_confidence",
      "left": "fear",
      "right": "confidence",
      "directions": {
        "fear_vs_confidence": {
          "formula": "normalize(mean(fear) - mean(confidence))"
