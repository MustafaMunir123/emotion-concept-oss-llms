      "score_rule": "cosine(residual, direction)",
      "percentage_rule": {
        "p_fear": "sigmoid(k * score)",
        "p_confidence": "1 - p_fear"
      }
    },
    {
      "pair_key": "love_vs_hate",
      "left": "love",
      "right": "hate",
      "directions": {
        "love_vs_hate": {
          "formula": "normalize(mean(love) - mean(hate))"
        },
        "hate_vs_love": {
